# Firebase client config — get these from `firebase_get_sdk_config` MCP, never copy from console.
# Copy this file to .env.local and fill in values. .env.local is gitignored.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
